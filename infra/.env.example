# Compose-time interpolation values (read by docker compose).
# App runtime secrets live in ../apps/api/.env

# Ngrok dev tunnel (https → api:8000)
# Token: dashboard.ngrok.com/get-started/your-authtoken
# Domain: dashboard.ngrok.com/domains (reserve one free static domain)
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# Frontend origin baked into web build
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# GitHub App slug (from github.com/apps/<slug>) — baked into web build
NEXT_PUBLIC_GITHUB_APP_SLUG=avinash-lineage
