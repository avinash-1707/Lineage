# Core
ENVIRONMENT=dev
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Postgres
DATABASE_URL=postgresql+asyncpg://lineage:lineage@localhost:5432/lineage

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=lineage_memory

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=changeme

# Google Gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIM=768

# Observability
SENTRY_DSN=
PROMETHEUS_ENABLED=true
