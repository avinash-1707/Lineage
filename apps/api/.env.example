# Core
ENVIRONMENT=dev
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Postgres
DATABASE_URL=postgresql+asyncpg://lineage:lineage@localhost:5432/lineage

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=lineage_memory

# GitHub App (installations + webhooks)
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=changeme

# GitHub OAuth (user login)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/auth/github/callback
GITHUB_OAUTH_SCOPES=read:user user:email

# JWT / sessions
JWT_SECRET=dev-insecure-secret-change-me-please-32+
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# Cookies
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
FRONTEND_ORIGIN=http://localhost:3000
POST_LOGIN_REDIRECT_PATH=/dashboard

# Rate limit
RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_PER_MINUTE=30

# Google Gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIM=768

# Observability
SENTRY_DSN=
PROMETHEUS_ENABLED=true
